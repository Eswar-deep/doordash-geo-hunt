# Google Maps Platform (Street View Static + Metadata + Geocoding)

GOOGLE_MAPS_API_KEY=



# Mapillary (free tier: https://www.mapillary.com/developer)

MAPILLARY_ACCESS_TOKEN=



# KartaView — public API, no key required



# Gemini vision (single model for all steps if VISION_LLM_PROVIDER=gemini)

GEMINI_API_KEY=

GEMINI_VISION_MODEL=gemini-3.5-flash

GEMINI_VISION_FALLBACK_MODEL=gemini-2.5-flash,gemini-3-flash-preview



# Azure Maps (geocoding / search — optional)

AZURE_MAPS_API_KEY=



# Vision provider: bedrock | gemini | openai | azure_openai | anthropic | cursor

VISION_LLM_PROVIDER=bedrock



# --- Tiered Claude (recommended: Sonnet for map/OCR, Opus for geoguesser/judge) ---



# AWS Bedrock (generate key: AWS Console → Amazon Bedrock → API keys)

AWS_BEARER_TOKEN_BEDROCK=

AWS_BEDROCK_REGION=us-east-1

AWS_BEDROCK_SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-6

AWS_BEDROCK_OPUS_MODEL_ID=us.anthropic.claude-opus-4-6
AWS_BEDROCK_OPUS_FALLBACK_MODEL_ID=us.anthropic.claude-opus-4-5-20251101-v1:0

# Optional per-step overrides:

# AWS_BEDROCK_MODEL_MAP=

# AWS_BEDROCK_MODEL_OCR=

# AWS_BEDROCK_MODEL_GEOGUESSER=

# AWS_BEDROCK_MODEL_JUDGE=

# Or IAM instead of bearer token:

# AWS_ACCESS_KEY_ID=

# AWS_SECRET_ACCESS_KEY=



# Azure AI Foundry / OpenAI (deployment names from your Foundry resource)

AZURE_OPENAI_API_KEY=

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/

AZURE_OPENAI_DEPLOYMENT_SONNET=claude-sonnet-4-6

AZURE_OPENAI_DEPLOYMENT_OPUS=claude-opus-4-6

AZURE_OPENAI_API_VERSION=2024-02-15-preview



# Direct Anthropic API (console.anthropic.com — separate from Bedrock)

ANTHROPIC_API_KEY=

ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6

ANTHROPIC_OPUS_MODEL=claude-opus-4-6



# Direct OpenAI (platform.openai.com)

OPENAI_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_VISION_MODEL_SONNET=gpt-4.1-mini

OPENAI_VISION_MODEL_OPUS=gpt-4.1



# Cursor API (optional — for SDK automation later)

CURSOR_API_KEY=

